# LLM providers — priorité : Anthropic > Infomaniak
ANTHROPIC_API_KEY=sk-ant-...

# Infomaniak AI Services (souverain, hébergé en Suisse)
# Token : https://manager.infomaniak.com/v3/ng/accounts/token/list (scope : ai)
# Product ID : visible dans manager.infomaniak.com > AI Tools
INFOMANIAK_API_KEY=
INFOMANIAK_PRODUCT_ID=
INFOMANIAK_MODEL=swiss-ai/Apertus-70B-Instruct-2509

# I14Y MCP server (Swiss interoperability platform)
I14Y_MCP_URL=https://mcp.i14y.d.c.bfs.admin.ch/mcp

# Local mock MCP server (auto-started by `semantic-bridge serve`)
MOCK_MCP_URL=http://localhost:8002/mcp

# Service ports
FASTAPI_PORT=8000
STREAMLIT_PORT=8501
MOCK_MCP_PORT=8002
OPEN_WEBUI_PORT=8080

# Open WebUI chat interface
WEBUI_AUTH=False
WEBUI_NAME=Semantic Bridge — Découverte Datasets I14Y

# Logging
LOG_LEVEL=INFO

# Paths
DATA_DIR=data
CACHE_DB_PATH=data/cache.db
FAISS_INDEX_PATH=data/faiss.index
